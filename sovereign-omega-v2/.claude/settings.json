      "Bash(tsx:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(zip:*)",
      "Bash(git:*)",
      "Bash(sha256sum:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cargo:*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(rustc --version)",
      "Bash(jq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
