      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Read(**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(scripts/**)",
      "Write(.claude/**)",
      "Write(.claude-plugin/**)",
      "Write(docs/**)",
      "Write(.env.example)",
      "Write(python/**)",
      "Write(packages/**)",
      "Write(../supabase/**)",
      "Write(../aegis-cl-psi/src/**)",
      "Write(../aegis-runtime/src/**)",
      "Write(../packages/**)",
      "Write(../hub/src/**)",
      "Write(../cockpit/src/**)",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read",
      "mcp__github__get_commit",
      "mcp__github__list_commits",
      "mcp__github__get_file_contents",
      "mcp__github__search_code",
      "mcp__github__actions_list",
      "mcp__github__actions_get",
      "mcp__github__get_job_logs",
      "mcp__github__list_branches",
      "mcp__github__issue_read",
      "mcp__github__list_issues",
      "mcp__github__add_issue_comment",
      "mcp__github__add_reply_to_pull_request_comment",
      "mcp__github__resolve_review_thread",
      "mcp__github__pull_request_review_write",
      "mcp__github__update_pull_request",
      "mcp__github__push_files",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__execute_sql",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__apply_migration",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__list_tables",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__get_project",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__get_logs",
      "mcp__71923ddf-e9ee-4959-b191-9ef0ac574e2a__list_migrations"
    ],
    "deny": [
      "Write(gate.py)",
      "Write(dna.py)",
      "Write(router.py)",
      "Write(docs/SOVEREIGN_OMEGA_INTEGRATED_SPEC_v2.md)",
      "Write(ARTIFACT_REGISTRY.md)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "result=$(cd \"${CLAUDE_PROJECT_DIR}\" && node scripts/verify-hashes.mjs 2>&1); if echo \"$result\" | grep -q 'VIOLATION\\|Error\\|error'; then echo \"{\\\"systemMessage\\\": \\\"⚠ FROZEN FILE VIOLATION — $result\\\"}\"; else echo \"{\\\"systemMessage\\\": \\\"✓ Constitutional files verified: gate.py · dna.py · router.py — all hashes match.\\\"}\"; fi",
            "statusMessage": "Verifying constitutional file hashes..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dirty=$(git -C \"${CLAUDE_PROJECT_DIR}\" status --porcelain 2>/dev/null | grep -v ' aegis-runtime/target/'); if [ -n \"$dirty\" ]; then count=$(echo \"$dirty\" | wc -l | tr -d ' '); echo \"{\\\"systemMessage\\\": \\\"$count uncommitted file(s) — commit and push before ending session.\\\"}\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-frozen-writes.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tier-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=$(cat 2>/dev/null | jq -r '.notification // empty' 2>/dev/null); if echo \"$msg\" | grep -q 'FROZEN FILE VIOLATION\\|HASH VIOLATION'; then echo \"{\\\"systemMessage\\\": \\\"⛔ CONSTITUTIONAL BREACH DETECTED — $msg — invoke guardian agent immediately\\\"}\"; elif echo \"$msg\" | grep -q 'UNCOMMITTED SRC'; then echo \"{\\\"systemMessage\\\": \\\"⚠ $msg — run Gate 8 and commit before continuing\\\"}\"; fi"
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "test"
  },
  "includeCoAuthoredBy": true
}
