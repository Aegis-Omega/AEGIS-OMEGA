# ── Required: Python bridge /claude endpoint ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Required: Multi-model BFT consensus ───────────────────────────────────────
# (weights: Claude 618, GPT-4o 191, Qwen 191 — see docs/MULTI_MODEL_CONSENSUS.md)
OPENAI_API_KEY=sk-...
VITE_DASHSCOPE_API_KEY=...
VITE_DASHSCOPE_MODEL=qwen-plus

# ── Bridge configuration ───────────────────────────────────────────────────────
AEGIS_BRIDGE_PORT=7890
AEGIS_BRIDGE_HOST=127.0.0.1

# ── Front-end apps ─────────────────────────────────────────────────────────────
# Used by cockpit, studio, and hub to connect to the Python bridge
VITE_BRIDGE_URL=http://localhost:7890

# ── Cockpit ───────────────────────────────────────────────────────────────────
VITE_OLLAMA_BASE_URL=http://localhost:11434

# ── Supabase (optional — only if using supabase/ integrations) ────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── GCP Cloud Run deployment (optional — only needed for deploy.yml) ──────────
# Configure in GitHub repository secrets, not here
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/.../workloadIdentityPools/...
# GCP_SERVICE_ACCOUNT=deploy@project.iam.gserviceaccount.com
# DASHSCOPE_API_KEY=...
