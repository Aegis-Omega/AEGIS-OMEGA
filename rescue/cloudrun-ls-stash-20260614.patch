diff --git a/supabase/functions/verify-token/index.ts b/supabase/functions/verify-token/index.ts
new file mode 100644
index 00000000..199f7023
--- /dev/null
+++ b/supabase/functions/verify-token/index.ts
@@ -0,0 +1,55 @@
+// Verify a server-issued grant token using HMAC-SHA256.
+// Deploy: supabase functions deploy verify-token --no-verify-jwt
+// Env vars: GRANT_SECRET
+import { CORS } from '../_shared/cors.ts'
+
+const GRANT_SECRET = Deno.env.get('GRANT_SECRET') ?? ''
+
+async function hmacVerify(data: string, sigB64: string): Promise<boolean> {
+  if (!GRANT_SECRET) return false
+  const key = await crypto.subtle.importKey(
+    'raw',
+    new TextEncoder().encode(GRANT_SECRET),
+    { name: 'HMAC', hash: 'SHA-256' },
+    false,
+    ['verify'],
+  )
+  const sig = Uint8Array.from(atob(sigB64), c => c.charCodeAt(0))
+  return crypto.subtle.verify('HMAC', key, sig, new TextEncoder().encode(data))
+}
+
+Deno.serve(async (req) => {
+  if (req.method === 'OPTIONS') return new Response(null, { headers: CORS })
+  if (req.method !== 'POST') {
+    return new Response(JSON.stringify({ error: 'Method not allowed' }), { status: 405, headers: CORS })
+  }
+
+  const { token } = await req.json() as { token?: string }
+  if (!token) {
+    return new Response(JSON.stringify({ valid: false }), { headers: { ...CORS, 'Content-Type': 'application/json' } })
+  }
+
+  const dotIdx = token.indexOf('.')
+  if (dotIdx === -1) {
+    return new Response(JSON.stringify({ valid: false }), { headers: { ...CORS, 'Content-Type': 'application/json' } })
+  }
+
+  const payloadB64 = token.slice(0, dotIdx)
+  const sigB64 = token.slice(dotIdx + 1)
+
+  try {
+    const payloadStr = atob(payloadB64)
+    const payload = JSON.parse(payloadStr) as { plan: string; tools: string[]; grantedAt: number; exp: number }
+
+    if (Date.now() > payload.exp) {
+      return new Response(JSON.stringify({ valid: false, reason: 'expired' }), { headers: { ...CORS, 'Content-Type': 'application/json' } })
+    }
+
+    const valid = await hmacVerify(payloadStr, sigB64)
+    return new Response(JSON.stringify({ valid, payload: valid ? payload : undefined }), {
+      headers: { ...CORS, 'Content-Type': 'application/json' },
+    })
+  } catch {
+    return new Response(JSON.stringify({ valid: false }), { headers: { ...CORS, 'Content-Type': 'application/json' } })
+  }
+})
