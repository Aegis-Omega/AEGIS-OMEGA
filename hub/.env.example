# Stripe payment links — create at dashboard.stripe.com → Payment Links
# Operator ($49): add metadata key "tier" = "operator" on the link
# Sovereign ($499): add metadata key "tier" = "sovereign" on the link
VITE_STRIPE_OPERATOR_LINK=https://buy.stripe.com/REPLACE_ME
VITE_STRIPE_SOVEREIGN_LINK=https://buy.stripe.com/REPLACE_ME

# Stripe webhook — add in dashboard.stripe.com → Webhooks:
#   Endpoint URL: https://rwehltdwpsncnwxzkwik.supabase.co/functions/v1/verify-stripe
#   Events: checkout.session.completed
# Then set the signing secret:
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_... --project-ref rwehltdwpsncnwxzkwik

