{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "swarm-brain",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "tools.swarm.equilibrium_server:app", "--host", "0.0.0.0", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "swarm-dashboard",
