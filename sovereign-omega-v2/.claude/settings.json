{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(tsx:*)",
      "Bash(tsc:*)",
      "Bash(vitest:*)",
      "Bash(zip:*)",
      "Bash(git:*)",
      "Bash(sha256sum:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cargo:*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(rustc --version)",
      "Read(**)",
      "Write(src/**)",
      "Write(test/**)",
      "Write(scripts/**)",
      "Write(.claude/**)",
      "Write(docs/**)",
      "Write(.env.example)",
      "Write(../aegis-runtime/src/**)"
    ],
    "deny": [
      "Write(gate.py)",
      "Write(dna.py)",
      "Write(router.py)",
      "Write(docs/SOVEREIGN_OMEGA_INTEGRATED_SPEC_v2.md)",
      "Write(ARTIFACT_REGISTRY.md)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "result=$(cd /home/user/myapp/sovereign-omega-v2 && node scripts/verify-hashes.mjs 2>&1); if echo \"$result\" | grep -q 'VIOLATION\\|Error\\|error'; then echo \"{\\\"systemMessage\\\": \\\"⚠ FROZEN FILE VIOLATION — $result\\\"}\"; else echo \"{\\\"systemMessage\\\": \\\"✓ Constitutional files verified: gate.py · dna.py · router.py — all hashes match.\\\"}\"; fi",
            "statusMessage": "Verifying constitutional file hashes..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dirty=$(git -C /home/user/myapp status --porcelain 2>/dev/null | grep -v ' aegis-runtime/target/'); if [ -n \"$dirty\" ]; then count=$(echo \"$dirty\" | wc -l | tr -d ' '); preview=$(echo \"$dirty\" | head -3 | tr '\\n' '|' | sed 's/|$//' | sed 's/|/ · /g'); echo \"{\\\"systemMessage\\\": \\\"There are uncommitted changes in the repository. Please commit and push these changes to the remote branch.\\\"}\"; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-frozen-writes.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tier-check.sh \"$CLAUDE_TOOL_INPUT_PATH\""
          }
        ]
      }
    ]
  },
  "env": {
    "NODE_ENV": "test"
  },
  "includeCoAuthoredBy": true
}
