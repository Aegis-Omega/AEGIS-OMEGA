            "timeout": 180,
            "statusMessage": "Installing npm dependencies..."
          },
          {
            "type": "command",
            "command": "cd /home/user/AEGIS--/sovereign-omega-v2 && node scripts/verify-hashes.mjs 2>&1 | tail -5",
            "timeout": 15,
            "statusMessage": "L7: verifying constitutional membrane..."
          },
          {
            "type": "command",
            "command": "node -e \"const fs=require('fs'); const base='/home/user/AEGIS--/sovereign-omega-v2/.claude/skills'; const read=f=>fs.readFileSync(base+'/'+f+'/SKILL.md','utf8'); const ctx=[read('automaton-workflow'),read('autopoiesis'),read('metacognition')].join('\\n\\n---\\n\\n'); console.log(JSON.stringify({hookSpecificOutput:{hookEventName:'SessionStart',additionalContext:ctx}}))\"",
            "timeout": 10,
            "statusMessage": "Loading automaton manifold (autopoiesis + metacognition + workflow)..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/user-prompt-intake.sh",
            "timeout": 5,
            "statusMessage": "L1-L7 intake..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/pre-commit-gate.sh",
            "timeout": 120,
            "statusMessage": "Gate 8 pre-commit check..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/pre-write-tier.sh",
            "timeout": 10,
            "statusMessage": "L6 ASSESS: tier classification..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/post-write.sh",
            "timeout": 120,
            "statusMessage": "Viability ring assertion..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); cmd=d.get('tool_input',{}).get('command',''); pushed='git push' in cmd; print(json.dumps({'systemMessage':'PUSHED — L7: check CI. Run /evening-seal when done.'})) if pushed else None\" 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Post-push CI reminder..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\": \"PRE-COMPACT: Preserve — current gate, open RALPH phase, active skill, pending commits, bridge t0_verdict, any uncommitted file changes.\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/post-compact-reanchor.sh",
            "timeout": 30,
            "statusMessage": "PostCompact: re-anchoring L7 + manifold..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import subprocess,json; s=subprocess.run(['git','status','--short'],cwd='/home/user/AEGIS--',capture_output=True,text=True).stdout.strip(); b=subprocess.run(['git','branch','--show-current'],cwd='/home/user/AEGIS--',capture_output=True,text=True).stdout.strip(); print(json.dumps({'systemMessage':f'STOP | branch:{b} | uncommitted:{s or chr(10)+\\\" none\\\"} — /evening-seal: Gate8 → commit → push'}))\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/AEGIS--/.claude/hooks/stop-constitutional-seal.sh",
            "timeout": 120,
            "statusMessage": "Constitutional seal: L7 + conditional typecheck...",
            "asyncRewake": true
          }
        ]
      }
    ]
  },
