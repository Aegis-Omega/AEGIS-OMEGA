diff --git a/supabase/functions/grant-access/index.ts b/supabase/functions/grant-access/index.ts
new file mode 100644
index 00000000..8390a8d5
--- /dev/null
+++ b/supabase/functions/grant-access/index.ts
@@ -0,0 +1,84 @@
+// Verify a Lemon Squeezy order_id and issue a server-signed HMAC-SHA256 grant token.
+// Also handles email-based restore flow when no order_id is present.
+// Deploy: supabase functions deploy grant-access --no-verify-jwt
+// Env vars: GRANT_SECRET (server-only, never VITE_ prefixed), SUPABASE_SERVICE_ROLE_KEY
+import { createClient } from 'https://esm.sh/@supabase/supabase-js@2'
+import { CORS } from '../_shared/cors.ts'
+
+const GRANT_SECRET = Deno.env.get('GRANT_SECRET') ?? ''
+
+async function hmacSign(data: string): Promise<string> {
+  const key = await crypto.subtle.importKey(
+    'raw',
+    new TextEncoder().encode(GRANT_SECRET),
+    { name: 'HMAC', hash: 'SHA-256' },
+    false,
+    ['sign'],
+  )
+  const sig = await crypto.subtle.sign('HMAC', key, new TextEncoder().encode(data))
+  return btoa(String.fromCharCode(...new Uint8Array(sig)))
+}
+
+const TOOLS: Record<string, string[]> = {
+  single:  ['platform-picker'],
+  starter: ['platform-picker', 'hook-generator'],
+  full:    ['platform-picker', 'hook-generator', 'content-calendar'],
+}
+
+const PLAN_RANK: Record<string, number> = { single: 1, starter: 2, full: 3 }
+
+Deno.serve(async (req) => {
+  if (req.method === 'OPTIONS') return new Response(null, { headers: CORS })
+  if (req.method !== 'POST') {
+    return new Response(JSON.stringify({ error: 'Method not allowed' }), { status: 405, headers: CORS })
+  }
+
+  if (!GRANT_SECRET) {
+    return new Response(JSON.stringify({ error: 'Server misconfigured' }), { status: 500, headers: CORS })
+  }
+
+  const supabase = createClient(
+    Deno.env.get('SUPABASE_URL') ?? '',
+    Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? '',
+  )
+
+  const body = await req.json() as { order_id?: string; email?: string }
+
+  let plan: string | null = null
+
+  if (body.order_id) {
+    const { data } = await supabase
+      .from('purchases')
+      .select('plan')
+      .eq('order_id', body.order_id)
+      .single()
+    plan = data?.plan ?? null
+  } else if (body.email) {
+    const { data } = await supabase
+      .from('purchases')
+      .select('plan')
+      .eq('email', body.email.toLowerCase().trim())
+    if (data?.length) {
+      plan = data.reduce((best: string, row: { plan: string }) => {
+        return (PLAN_RANK[row.plan] ?? 0) > (PLAN_RANK[best] ?? 0) ? row.plan : best
+      }, 'single')
+    }
+  }
+
+  if (!plan || !TOOLS[plan]) {
+    return new Response(JSON.stringify({ found: false }), {
+      headers: { ...CORS, 'Content-Type': 'application/json' },
+    })
+  }
+
+  const grantedAt = Date.now()
+  const exp = grantedAt + 365 * 24 * 60 * 60 * 1000
+  const payload = { plan, tools: TOOLS[plan], grantedAt, exp }
+  const dataStr = JSON.stringify(payload)
+  const sig = await hmacSign(dataStr)
+  const token = btoa(dataStr) + '.' + sig
+
+  return new Response(JSON.stringify({ found: true, token, plan }), {
+    headers: { ...CORS, 'Content-Type': 'application/json' },
+  })
+})
