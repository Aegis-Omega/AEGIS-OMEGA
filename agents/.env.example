# AEGIS agent batch bridge — environment template.
# Copy to agents/.env and fill in. NEVER commit the filled-in .env.

# Required for any live call. Direct API key (credits). Do NOT enable Vertex here.
ANTHROPIC_API_KEY=

# Model for batched agent work. Default is Opus 4.8.
AEGIS_SWARM_MODEL=claude-opus-4-8

# ── Cost guardrails (the whole point) ───────────────────────────────────────
# Per-agent output ceiling in the batch. Lower = cheaper. Default 2048.
AEGIS_BATCH_MAX_TOKENS=2048
# Hard USD ceiling for a single batch. If the worst-case estimate exceeds this,
# the bridge REFUSES to submit. Default 1.00.
AEGIS_BATCH_MAX_USD=1.00
# Safety switch. The bridge runs DRY (no API call, $0) unless this is exactly "1".
AEGIS_BATCH_LIVE=0

# File-backed memory store (no Redis needed). Default: agents/.batch_state
# AEGIS_BATCH_STORE=agents/.batch_state
